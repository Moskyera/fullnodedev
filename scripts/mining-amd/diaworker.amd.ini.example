; HACD diamond miner - CPU/fullnode mining only
; OpenCL and GPU tuning apply to HAC poworker, not HACD.
; Requires [diamondminer] enable = true in hacash.config.ini.

connect = 127.0.0.1:8080
supervene = 4

[efficiency]
mode = profit
power_cost_kwh = 0.15
cpu_watts_per_thread = 8
dynamic_supervene = true
supervene_min = 1
supervene_max = 0
benchmark_seconds = 0

[gpu]
use_opencl = false
use_cuda = false
cpu_assist = false
